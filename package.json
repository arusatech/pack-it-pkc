{
  "name": "@annadata/pack-it-pkc",
  "version": "1.0.0",
  "description": "Convert documents to Markdown and pack into PKC format (MarkItDown JS port with GGUF via llama-cpp-pro)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./inference/capacitor": {
      "types": "./dist/inference/capacitor-provider.d.ts",
      "import": "./dist/inference/capacitor-provider.js",
      "require": "./dist/inference/capacitor-provider.cjs"
    },
    "./pdf/editor": {
      "types": "./dist/pdf/editor.d.ts",
      "import": "./dist/pdf/editor.js",
      "require": "./dist/pdf/editor.cjs"
    },
    "./pdf/editor.css": "./dist/pdf/pdf-canvas-editor.css",
    "./assets/manifest": {
      "types": "./dist/assets/manifest.d.ts",
      "import": "./dist/assets/manifest.js",
      "require": "./dist/assets/manifest.cjs"
    },
    "./assets/*": "./dist/assets/*"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-plugin-assets.mjs",
    "prepublishOnly": "npm run build && npm test",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:manual": "vite --config test/manual-convert/vite.config.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "markdown",
    "document-converter",
    "pkc",
    "gguf",
    "llama-cpp",
    "llama-cpp-pro",
    "markitdown",
    "capacitor",
    "pwa"
  ],
  "author": "Mr. Yakub Mohammad <yakub@annadata.ai>",
  "license": "MIT",
  "dependencies": {
    "chardet": "^2.1.0",
    "cheerio": "^1.1.0",
    "fast-xml-parser": "^5.2.5",
    "fflate": "^0.8.2",
    "file-type": "^21.0.0",
    "flexsearch": "^0.8.212",
    "jszip": "^3.10.1",
    "katex": "^0.17.0",
    "mammoth": "^1.9.0",
    "mupdf": "^1.28.0",
    "music-metadata": "^11.0.3",
    "turndown": "^7.2.0",
    "xlsx": "^0.18.5",
    "youtube-transcript-api-js": "^3.0.3"
  },
  "optionalDependencies": {
    "@kenjiuno/msgreader": "^1.27.1"
  },
  "peerDependencies": {
    "@capacitor/filesystem": ">=6.0.0",
    "llama-cpp-pro": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "@capacitor/filesystem": {
      "optional": true
    },
    "llama-cpp-pro": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/node": "^26.1.0",
    "@types/turndown": "^5.0.5",
    "buffer": "^6.0.3",
    "eslint": "^10.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.9"
  }
}
