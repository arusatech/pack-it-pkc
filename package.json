{
  "name": "@annadata/pack-it-pkc",
  "version": "1.0.0",
  "description": "Convert documents to Markdown and pack into PKC format (MarkItDown JS port with GGUF inference)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./inference/capacitor": {
      "types": "./dist/inference/capacitor-provider.d.ts",
      "import": "./dist/inference/capacitor-provider.js"
    },
    "./inference/node": {
      "types": "./dist/inference/node-provider.d.ts",
      "import": "./dist/inference/node-provider.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:manual": "vite --config test/manual-convert/vite.config.ts"
  },
  "keywords": [
    "markdown",
    "document-converter",
    "pkc",
    "gguf",
    "llama-cpp",
    "markitdown"
  ],
  "author": "Mr. Yakub Mohammad <yakub@annadata.ai>",
  "license": "MIT",
  "dependencies": {
    "chardet": "^2.1.0",
    "cheerio": "^1.1.0",
    "fast-xml-parser": "^5.2.5",
    "fflate": "^0.8.2",
    "file-type": "^21.0.0",
    "jszip": "^3.10.1",
    "katex": "^0.17.0",
    "mammoth": "^1.9.0",
    "mupdf": "^1.28.0",
    "music-metadata": "^11.0.3",
    "turndown": "^7.2.0",
    "xlsx": "^0.18.5",
    "youtube-transcript-api-js": "^3.0.3"
  },
  "optionalDependencies": {
    "@kenjiuno/msgreader": "^1.27.1"
  },
  "peerDependencies": {
    "llama-cpp-capacitor": ">=0.2.0",
    "node-llama-cpp": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "llama-cpp-capacitor": {
      "optional": true
    },
    "node-llama-cpp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/node": "^26.1.0",
    "@types/turndown": "^5.0.5",
    "buffer": "^6.0.3",
    "eslint": "^10.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.9"
  }
}
